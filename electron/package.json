{
  "name": "anki-swedish",
  "version": "1.0.0",
  "description": "Swedish Anki card generator",
  "main": "main.js",
  "scripts": {
    "dev": "NODE_ENV=development electron .",
    "dev:vite": "vite src",
    "build": "vite build && electron-builder",
    "start": "electron ."
  },
  "build": {
    "appId": "com.danielreedy.anki-swedish",
    "productName": "Swedish Anki",
    "directories": {
      "output": "release"
    },
    "mac": {
      "target": "dmg",
      "category": "public.app-category.education"
    },
    "files": [
      "main.js",
      "preload.js",
      "ui-build/**/*"
    ],
    "extraResources": [
      {
        "from": "../flask-dist/flask-server",
        "to": "flask-server",
        "filter": ["**/*"]
      },
      {
        "from": "../.env",
        "to": ".env"
      }
    ]
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.0.0",
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0",
    "vite": "^5.0.0"
  }
}
